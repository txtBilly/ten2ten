# ============================================================
# Ten2Ten environment variables — copy to .env.local and fill
# ============================================================

# ---- Supabase ----
# From your Supabase project: Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, never expose

# ---- Stripe ----
# From dashboard.stripe.com -> Developers -> API keys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price configuration
CONTACT_BUNDLE_PRICE_CENTS=10000     # $100 = 3 contact credits
BG_CHECK_FEE_CENTS=3500              # $35 one-time, bundled on first purchase

# ---- Background check (identity + credit score only) ----
BACKGROUND_CHECK_PROVIDER=mock       # mock | (future: smartmove)
MOCK_BG_CHECK_RESULT=pass            # pass | no_match | inconclusive | technical_failure
MOCK_CREDIT_SCORE=680                # returned when MOCK_BG_CHECK_RESULT=pass

# ---- Twilio (SMS) ----
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your-token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX     # your A2P-verified number

# ---- Resend (email) ----
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hello@ten2ten.app

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
